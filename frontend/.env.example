# Swarmtally Frontend – Environment Variables Template
# Copy this to .env.local for local development
# Set these as environment variables in Vercel for production

# URL of the FastAPI backend (server-side proxy)
API_URL=http://localhost:8000

# URL of the FastAPI backend (visible to browser, for loading result images)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── For Vercel + Render deployment, set to your Render backend URL: ──────────
# API_URL=https://swarmtally-api.onrender.com
# NEXT_PUBLIC_API_URL=https://swarmtally-api.onrender.com
