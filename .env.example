# =============================================================================
# Swarmtally – Root Environment Variables Example
# Copy this file to .env for Docker Compose local development:
#   cp .env.example .env
#
# Individual service .env.example files exist in backend/ and frontend/
# for non-Docker local development.
# =============================================================================

# ── Backend ───────────────────────────────────────────────────────────────────
# URL of the deployed frontend (for CORS allow-list)
FRONTEND_URL=http://localhost:3000

# Port the FastAPI server listens on (Render sets this automatically)
PORT=8000

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Server-side: URL used by the Next.js API proxy route to reach the backend
# In Docker: use the internal service name "backend"
API_URL=http://backend:8000

# Client-side: URL used by the browser to fetch annotated result images
# Must be publicly accessible from the browser (use real URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Production (Vercel + Render) ─────────────────────────────────────────────
# Set these in your Vercel and Render dashboards:
#
# On Vercel:
#   API_URL            = https://your-app.onrender.com
#   NEXT_PUBLIC_API_URL = https://your-app.onrender.com
#
# On Render:
#   FRONTEND_URL       = https://your-app.vercel.app
